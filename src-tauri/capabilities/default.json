{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri/capability-schema.json",
  "identifier": "default",
  "description": "Default capabilities for RetroPlay",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-decorations",
    "core:window:allow-unmaximize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-resizable",
    "core:window:allow-set-min-size",
    "dialog:default",
    "dialog:allow-open",
    "shell:default"
  ]
}
